
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>TONGTONG's SPACE · V3.8</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;500;700&display=swap');
        :root {
            --bg: #030712; --primary: #0ea5e9; --secondary: #818cf8; --accent: #fbbf24;
            --danger: #ef4444; --glass: rgba(15, 23, 42, 0.6); --border: rgba(56, 189, 248, 0.2);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: var(--bg); color: #f8fafc; font-family: 'Rajdhani', sans-serif; min-height: 100vh; overflow-x: hidden; }
        .bg-grid { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-image: linear-gradient(rgba(14, 165, 233, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(14, 165, 233, 0.05) 1px, transparent 1px); background-size: 50px 50px; z-index: -1; transform: rotateX(45deg); animation: moveGrid 20s linear infinite; }
        @keyframes moveGrid { from { background-position: 0 0; } to { background-position: 0 500px; } }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        header { text-align: center; margin-bottom: 30px; }
        .date-badge { font-family: 'Orbitron'; font-size: 0.65rem; color: var(--primary); border: 1px solid var(--primary); padding: 4px 15px; display: inline-block; margin-bottom: 10px; }
        h1 { font-family: 'Orbitron'; font-weight: 900; font-size: 1.8rem; letter-spacing: 2px; text-shadow: 0 0 20px rgba(14, 165, 233, 0.5); }
        
        /* RESTORED COOL REWARD CARD EFFECTS */
        .reward-card { 
            background: var(--glass); 
            border: 1px solid var(--border); 
            border-radius: 20px; 
            padding: 40px 20px; 
            text-align: center; 
            position: relative; 
            overflow: hidden; 
            margin-bottom: 30px; 
            backdrop-filter: blur(10px); 
        }
        .reward-card::before {
            content: ''; position: absolute;
            top: -50%; left: -50%; width: 200%; height: 200%;
            background: conic-gradient(transparent, var(--primary), transparent 40%);
            animation: rotate 4s linear infinite;
            opacity: 0.2;
        }
        @keyframes rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        .reward-inner { position: relative; z-index: 2; }
        
        .reward-value { font-family: 'Orbitron'; font-size: 5rem; font-weight: 900; color: var(--accent); text-shadow: 0 0 30px rgba(251, 191, 36, 0.4); }
        .section-title { font-size: 0.9rem; font-weight: 700; letter-spacing: 5px; color: var(--primary); border-left: 3px solid var(--primary); padding-left: 15px; margin: 40px 0 20px; text-transform: uppercase; }
        .task-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); margin-bottom: 12px; border-radius: 12px; display: flex; align-items: center; padding: 20px; animation: slideIn 0.5s ease-out forwards; }
        @keyframes slideIn { from { transform: translateX(-30px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        .task-icon { font-family: 'Orbitron'; font-size: 1.2rem; font-weight: 900; color: var(--primary); opacity: 0.3; margin-right: 20px; }
        .task-cn { font-size: 1rem; font-weight: 700; color: #fff; }
        .task-fr { font-size: 0.8rem; color: #64748b; font-style: italic; }
        .empty-msg { text-align: center; padding: 40px; color: var(--accent); font-family: 'Orbitron'; font-size: 0.8rem; letter-spacing: 2px; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .action-box { background: var(--glass); border: 1px solid var(--border); padding: 25px; border-radius: 15px; text-decoration: none; color: inherit; transition: 0.3s; }
        .action-box:hover { border-color: var(--primary); transform: translateY(-5px); }
        .action-box h3 { color: var(--primary); font-size: 0.8rem; letter-spacing: 2px; margin-bottom: 10px; }
        .btn-launch { grid-column: span 2; background: linear-gradient(90deg, var(--primary), var(--secondary)); padding: 30px; border-radius: 15px; text-align: center; color: #000; font-weight: 900; font-family: 'Orbitron'; font-size: 1.5rem; text-decoration: none; box-shadow: 0 10px 0 #0369a1; transition: 0.1s; margin-bottom: 15px; }
        .btn-launch:active { transform: translateY(5px); box-shadow: 0 5px 0 #0369a1; }
        footer { text-align: center; margin-top: 100px; padding-bottom: 50px; color: #334155; font-size: 0.6rem; letter-spacing: 3px; font-weight: 700; }
    </style>
</head>
<body>
    <div class="bg-grid"></div>
    <div class="container">
        <header>
            <div class="date-badge">2026年03月05日 // 05 March 2026</div>
            <h1>TONGTONG's SPACE<br><span style="opacity: 0.5; font-size: 1.2rem;">童童空间</span></h1>
        </header>
        <div class="reward-card">
            <div class="reward-inner">
                <div class="reward-value">100.0 <span style="font-size: 1.2rem; vertical-align: middle;">EUR</span></div>
                <div style="font-size: 0.6rem; letter-spacing: 2px; color: var(--primary);">CREDIT BALANCE AVAILABLE</div>
            </div>
        </div>
                <div class="section-title">Active Mission List</div>
        <div id="tasks-container" style="margin-bottom: 40px;">
            <!-- 任务将动态加载到这里 -->
            <div class="empty-msg" id="loading-msg">⏳ 正在加载今日任务...</div>
        </div>
        
        <!-- Supabase客户端库 -->
        <script src="https://unpkg.com/@supabase/supabase-js@2"></script>
        
        <script>
        // Supabase配置（与法语学习系统相同）
        const SUPABASE_CONFIG = {
            url: 'https://ghbmmnapyupusmyxjkvv.supabase.co',
            key: 'sb_publishable_MkMhoECq7wo5qFi3K9Shcg_7LiPM1oU'
        };
        
        let supabaseClient = null;
        
        // 初始化Supabase客户端
        function initSupabase() {
            try {
                if (window.supabase && SUPABASE_CONFIG.url && SUPABASE_CONFIG.key) {
                    supabaseClient = window.supabase.createClient(SUPABASE_CONFIG.url, SUPABASE_CONFIG.key);
                    console.log('✅ Supabase客户端初始化成功');
                    return true;
                } else {
                    console.warn('❌ Supabase配置不完整或库未加载');
                    return false;
                }
            } catch (error) {
                console.error('❌ Supabase初始化失败:', error);
                return false;
            }
        }
        
        // 从Supabase获取今日任务
        async function loadTodayTasks() {
            const container = document.getElementById('tasks-container');
            const loadingMsg = document.getElementById('loading-msg');
            
            try {
                // 初始化Supabase
                if (!initSupabase() || !supabaseClient) {
                    throw new Error('Supabase客户端初始化失败');
                }
                
                // 从Supabase视图获取格式化任务数据
                const { data, error } = await supabaseClient
                    .from('reminders_tasks_formatted')
                    .select('*')
                    .order('is_today', { ascending: false })
                    .order('due_date', { ascending: true, nullsLast: true })
                    .order('created_at', { ascending: false })
                    .limit(20);
                
                if (error) throw error;
                
                const tasks = data || [];
                console.log(`📊 从Supabase获取到 ${tasks.length} 个任务`);
                
                // 获取今日日期
                const today = new Date().toISOString().split('T')[0]; // YYYY-MM-DD
                
                // 过滤出今日任务（无论完成状态）
                const todayTasks = tasks.filter(task => {
                    return task.is_today === true;
                });
                
                // 确定要显示的任务
                let tasksToShow = todayTasks;
                let showAllCompleted = false;
                
                if (todayTasks.length === 0) {
                    // 没有今日任务，显示最近的未完成任务
                    tasksToShow = tasks.filter(task => !task.completed).slice(0, 5);
                    if (tasksToShow.length === 0) {
                        // 所有任务都已完成，显示最近的5个已完成任务
                        tasksToShow = tasks.slice(0, 5);
                        showAllCompleted = true;
                    }
                }
                
                // 清空容器
                container.innerHTML = '';
                
                if (tasksToShow.length === 0) {
                    container.innerHTML = '<div class="empty-msg">✅ 今日任务已全部完成！</div>';
                    return;
                }
                
                // 渲染任务卡片
                tasksToShow.forEach((task, index) => {
                    const taskCard = createTaskCardFromSupabase(task, index * 0.1);
                    container.appendChild(taskCard);
                });
                
                // 如果显示的是所有已完成任务，添加说明
                if (showAllCompleted && tasksToShow.length > 0) {
                    const info = document.createElement('div');
                    info.className = 'empty-msg';
                    info.style.fontSize = '0.7rem';
                    info.style.marginTop = '10px';
                    info.textContent = '所有任务均已完成 ✅';
                    container.appendChild(info);
                }
                
            } catch (error) {
                console.error('加载任务失败:', error);
                loadingMsg.innerHTML = '❌ 无法从Supabase加载任务: ' + error.message;
                loadingMsg.style.color = 'var(--danger)';
                
                // 回退：显示静态示例
                setTimeout(() => {
                    if (container.children.length <= 1) { // 只有错误消息
                        container.innerHTML = '<div class="empty-msg" style="color: var(--accent);">⚠️ 使用示例任务（Supabase连接失败）</div>' + getFallbackTasks();
                    }
                }, 2000);
            }
        }
        
        // 为Supabase数据创建任务卡片
        function createTaskCardFromSupabase(task, delay) {
            const taskCard = document.createElement('div');
            taskCard.className = 'task-card';
            taskCard.style.animationDelay = `${delay}s`;
            
            const today = new Date().toISOString().split('T')[0];
            const extractedDate = task.extracted_date || task.due_date;
            const isToday = extractedDate === today;
            const newBadge = isToday ? ' 🆕' : '';
            
            // 使用视图中的格式化字段
            const displayIcon = task.completed ? '✅' : (task.icon || '⏳');
            const cnText = task.chinese_text || task.title || '无标题';
            const frText = task.french_text || '';
            const statusText = task.completed ? '已完成' : '待完成';
            const displayDate = extractedDate || '无日期';
            
            taskCard.innerHTML = `
                <div class="card-glow"></div>
                <div class="task-icon">${displayIcon}</div>
                <div class="task-info">
                    <div class="task-cn">${cnText}${newBadge}</div>
                    ${frText ? '<div class="task-fr">' + frText + '</div>' : ''}
                    <div class="task-status">${displayDate} • ${statusText}</div>
                </div>
            `;
            
            // 如果任务已完成，添加半透明效果
            if (task.completed) {
                taskCard.style.opacity = '0.7';
                taskCard.style.filter = 'grayscale(20%)';
            }
            
            return taskCard;
        }
        
        // 回退静态任务
        function getFallbackTasks() {
            const today = new Date().toISOString().split('T')[0];
            return `
                <div class="task-card" style="animation-delay: 0.0s">
                    <div class="card-glow"></div>
                    <div class="task-icon">🎻</div>
                    <div class="task-info">
                        <div class="task-cn">小提琴练习 (20分钟)</div>
                        <div class="task-fr">Pratique du violon</div>
                        <div class="task-status">${today} • 待完成</div>
                    </div>
                </div>
                <div class="task-card" style="animation-delay: 0.1s">
                    <div class="card-glow"></div>
                    <div class="task-icon">📚</div>
                    <div class="task-info">
                        <div class="task-cn">学校作业 (Devoirs)</div>
                        <div class="task-fr">Devoirs scolaires</div>
                        <div class="task-status">${today} • 待完成</div>
                    </div>
                </div>
            `;
        }
        
        // 解析任务标题
        function parseTaskTitle(title) {
            if (!title) return { date: '', icon: '⏳', cnText: '无标题', frText: '' };
            
            // 默认值
            let date = '';
            let icon = '⏳';
            let cnText = title;
            let frText = '';
            
            // 提取日期 [2026-03-05]
            const dateMatch = title.match(/\[(\d{4}-\d{2}-\d{2})\]/);
            if (dateMatch) {
                date = dateMatch[1];
                title = title.replace(dateMatch[0], '').trim();
            }
            
            // 提取图标（第一个emoji或符号）
            // 匹配任何非字母数字、非空格的字符（包括中文标点）
            const iconMatch = title.match(/^([^\w\s\u4e00-\u9fa5]+\s*)/u);
            if (iconMatch) {
                icon = iconMatch[1].trim();
                title = title.replace(iconMatch[0], '').trim();
            }
            
            // 提取法文部分（括号内）
            const frMatch = title.match(/\(([^)]+)\)/);
            if (frMatch) {
                frText = frMatch[1];
                title = title.replace(frMatch[0], '').trim();
            }
            
            // 剩余的是中文部分
            cnText = title.trim();
            if (!cnText && frText) {
                cnText = frText;
                frText = '';
            }
            
            return { date, icon, cnText, frText };
        }
        
        // 创建任务卡片
        function createTaskCard(task, delay) {
            const { date, icon, cnText, frText } = parseTaskTitle(task.title);
            
            const taskCard = document.createElement('div');
            taskCard.className = 'task-card';
            taskCard.style.animationDelay = delay + 's';
            
            const today = new Date().toISOString().split('T')[0];
            const isToday = date === today;
            const newBadge = isToday ? ' 🆕' : '';
            
            // 根据完成状态选择图标和状态文本
            const statusIcon = task.completed ? '✅' : '⏳';
            const statusText = task.completed ? '已完成' : '待完成';
            const displayIcon = task.completed ? '✅' : (icon || '⏳');
            
            taskCard.innerHTML = `
                <div class="card-glow"></div>
                <div class="task-icon">${displayIcon}</div>
                <div class="task-info">
                    <div class="task-cn">${cnText}${newBadge}</div>
                    ${frText ? '<div class="task-fr">' + frText + '</div>' : ''}
                    <div class="task-status">${date || '无日期'} • ${statusText}</div>
                </div>
            `;
            
            // 如果任务已完成，添加半透明效果
            if (task.completed) {
                taskCard.style.opacity = '0.7';
                taskCard.style.filter = 'grayscale(20%)';
            }
            
            return taskCard;
        }
        
        // 页面加载时获取任务
        document.addEventListener('DOMContentLoaded', loadTodayTasks);
        </script><div class="section-title">Knowledge Interface</div>
        <div class="grid-2">
            <a href="https://tongtong2016.com/french_mot.html" class="btn-launch">Le Trésor des Mots</a>
            <a href="school_vocabulary.html" class="action-box" style="border-color: #818cf8;">
                <h3>LEXIQUE</h3>
                <p style="font-size: 0.75rem; color: #94a3b8;">学校法语生词本</p>
            </a>
            <a href="exam_hub.html" class="action-box" style="border-color: var(--accent);">
                <h3>REVISION</h3>
                <p style="font-size: 0.75rem; color: #94a3b8;">复习备考中心</p>
            </a>
            <a href="english_learning_hub.html" class="action-box">
                <h3>ENGLISH</h3>
                <p style="font-size: 0.75rem; color: #94a3b8;">Write a summary paragraph about Anatole Latuile, Un Max de Surprises.</p>
            </a>
            <a href="violin_learning_hub.html" class="action-box">
                <h3>VIOLIN</h3>
                <p style="font-size: 0.75rem; color: #94a3b8;">1. 听赏音频；2.《施拉迪克》第一页拉完（不反复）。</p>
            </a>
        </div>
        <footer>V3.8-VIBE-RESTORED | © ATOM TONG 2026 | MISSION_COMMAND</footer>
    </div>
</body>
</html>
    